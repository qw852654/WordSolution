<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="TaskPaneApp">
  <Id>3ffa2c8c-31f1-4359-a66d-371b84318350</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Contoso</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="题库"/>
  <Description DefaultValue="A template to get started."/>
  <IconUrl DefaultValue="https://localhost:5283/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://localhost:5283/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://localhost:5283/help"/>
  <AppDomains>
    <AppDomain>https://localhost:5283</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Document"/>
  </Hosts>
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="SharedRuntime" MinVersion="1.1"/>
    </Sets>
  </Requirements>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:5283/taskpane.html"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <Runtimes>
          <Runtime resid="Taskpane.Url" lifetime="long" />
        </Runtimes>
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>
          <FunctionFile resid="Taskpane.Url"/>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="CommandsGroup">
                <Label resid="CommandsGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>
                <Control xsi:type="Button" id="TaskpaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
            <CustomTab id="QuestionBankTab">
              <Group id="QuestionBankGroup">
                <Label resid="QuestionBankGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>
                <Control xsi:type="Button" id="QuestionBankHomeButton">
                  <Label resid="QuestionBankHomeButton.Label"/>
                  <Supertip>
                    <Title resid="QuestionBankHomeButton.Label"/>
                    <Description resid="QuestionBankHomeButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>OpenQuestionBankHome</FunctionName>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="QuestionBankRecordButton">
                  <Label resid="QuestionBankRecordButton.Label"/>
                  <Supertip>
                    <Title resid="QuestionBankRecordButton.Label"/>
                    <Description resid="QuestionBankRecordButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>OpenQuestionBankRecord</FunctionName>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="QuestionBankFilterButton">
                  <Label resid="QuestionBankFilterButton.Label"/>
                  <Supertip>
                    <Title resid="QuestionBankFilterButton.Label"/>
                    <Description resid="QuestionBankFilterButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>OpenQuestionBankFilter</FunctionName>
                  </Action>
                </Control>
              </Group>
              <Label resid="QuestionBankTab.Label"/>
            </CustomTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://localhost:5283/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://localhost:5283/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://localhost:5283/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://go.microsoft.com/fwlink/?LinkId=276812"/>
        <bt:Url id="Commands.Url" DefaultValue="https://localhost:5283/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://localhost:5283/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="Get started with your sample add-in!"/>
        <bt:String id="CommandsGroup.Label" DefaultValue="Commands Group"/>
        <bt:String id="TaskpaneButton.Label" DefaultValue="Show Task Pane"/>
        <bt:String id="QuestionBankTab.Label" DefaultValue="题库"/>
        <bt:String id="QuestionBankGroup.Label" DefaultValue="题库宸ュ叿"/>
        <bt:String id="QuestionBankHomeButton.Label" DefaultValue="首页"/>
        <bt:String id="QuestionBankRecordButton.Label" DefaultValue="录题"/>
        <bt:String id="QuestionBankFilterButton.Label" DefaultValue="选题"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Your sample add-in loaded successfully. Go to the HOME tab and click the 'Show Task Pane' button to get started."/>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Click to Show a Task Pane"/>
        <bt:String id="QuestionBankHomeButton.Tooltip" DefaultValue="鎵撳紑题库首页"/>
        <bt:String id="QuestionBankRecordButton.Tooltip" DefaultValue="鐩存帴杩涘叆录题椤甸潰"/>
        <bt:String id="QuestionBankFilterButton.Tooltip" DefaultValue="鐩存帴杩涘叆选题椤甸潰"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>

