<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="基本单元UI.题目容器"
             Height="500" av:DesignWidth="555.979">
    <!-- 外层 Border -->
    <Border BorderBrush="Black" BorderThickness="2" Margin="5" ClipToBounds="True">
        <!-- 内层 Border，边框设置为 0 -->
        <Border BorderBrush="Transparent" BorderThickness="0" Margin="0" ClipToBounds="True">
            <Grid>
                <!-- DocumentViewer -->
                <DocumentViewer x:Name="documentViewer" Margin="0,0,-26,-39" />

                <!-- ComboBox -->
                <ComboBox x:Name="难度" HorizontalAlignment="Left" VerticalAlignment="Top" Width="120" Height="33"/>
                <Button Content="编辑题目" HorizontalAlignment="Left" Margin="120,0,0,0" VerticalAlignment="Top" Height="33" Click="Button_Click" Width="53"/>
            </Grid>
        </Border>
    </Border>
</UserControl>


